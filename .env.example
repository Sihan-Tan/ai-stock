# Database (default PostgreSQL; switch to MySQL via DATABASE_URL)
DATABASE_URL=postgresql+psycopg://desk:desk@localhost:5432/desk
# DATABASE_URL=mysql+pymysql://desk:desk@localhost:3306/desk

# Trading mode: paper | live
TRADE_MODE=paper

# ML engine: lightgbm | xgboost
ML_ENGINE=lightgbm

# LLM for nanobot research chat
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Feishu alert webhook
FEISHU_WEBHOOK_URL=
FEISHU_SIGN_SECRET=

# miniQMT
QMT_USERDATA_PATH=C:\QMT\userdata_mini
QMT_ACCOUNT_ID=

# Paper account
PAPER_INITIAL_CASH=1000000

# Backtest fees (A-share approximate)
# 买入佣金率 / 卖出佣金率（不含印花税）/ 印花税（仅卖出）/ 单笔最低佣金（元）/ 滑点
BACKTEST_BUY_COMMISSION=0.00025
BACKTEST_SELL_COMMISSION=0.00025
BACKTEST_STAMP_DUTY=0.001
BACKTEST_MIN_COMMISSION=5
BACKTEST_SLIPPAGE=0.001

# Order risk limits
# 单笔最大仓位：占总权益百分比（0-100）；与单笔最大金额取较小者
RISK_MAX_ORDER_POSITION_PCT=10
RISK_MAX_ORDER_NOTIONAL=50000
RISK_MAX_DAILY_NOTIONAL=200000
